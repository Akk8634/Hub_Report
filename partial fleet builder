<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fleet Adjustment System</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;500;600;700;900&family=Barlow+Condensed:wght@400;600;700;900&display=swap');

  :root {
    --bg:        #0d0f12;
    --bg2:       #13171d;
    --bg3:       #1a1f28;
    --border:    #2a3040;
    --border2:   #3a4558;
    --accent:    #f0a500;
    --accent2:   #e06c00;
    --green:     #2dbe6c;
    --yellow:    #f0c040;
    --red:       #e05050;
    --blue:      #4a9eff;
    --text:      #d8dde8;
    --text2:     #8a95a8;
    --text3:     #5a6478;
    --mono:      'Share Tech Mono', monospace;
    --sans:      'Barlow', sans-serif;
    --cond:      'Barlow Condensed', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── HEADER ── */
  .header {
    background: var(--bg2);
    border-bottom: 2px solid var(--accent);
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    height: 56px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-icon {
    width: 32px; height: 32px;
    background: var(--accent);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .header-icon svg { width: 16px; height: 16px; fill: #000; }
  .header-title {
    font-family: var(--cond);
    font-size: 22px;
    font-weight: 900;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text);
  }
  .header-title span { color: var(--accent); }
  .header-sub {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text3);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-left: auto;
  }

  /* ── TABS ── */
  .tabs {
    display: flex;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    gap: 2px;
  }
  .tab-btn {
    font-family: var(--cond);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 14px 22px;
    border: none;
    background: transparent;
    color: var(--text3);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.15s;
    position: relative;
    top: 1px;
  }
  .tab-btn:hover { color: var(--text2); }
  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .tab-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: #000;
    font-size: 9px;
    font-weight: 900;
    border-radius: 2px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    margin-left: 6px;
    vertical-align: middle;
  }

  /* ── LAYOUT ── */
  .main { padding: 24px; max-width: 1400px; margin: 0 auto; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── SECTION / CARD ── */
  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    margin-bottom: 20px;
  }
  .card-header {
    padding: 12px 18px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg3);
  }
  .card-title {
    font-family: var(--cond);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
  }
  .card-body { padding: 18px; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }

  /* ── TEXTAREA ── */
  textarea {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.6;
    padding: 12px;
    resize: vertical;
    outline: none;
    transition: border-color 0.15s;
  }
  textarea:focus { border-color: var(--accent); }
  textarea::placeholder { color: var(--text3); }

  /* ── INPUTS ── */
  input[type="text"], input[type="time"], select {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    font-family: var(--sans);
    font-size: 13px;
    padding: 7px 10px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }
  input:focus, select:focus { border-color: var(--accent); }
  input::placeholder { color: var(--text3); }

  /* ── BUTTONS ── */
  .btn {
    font-family: var(--cond);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 9px 20px;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-primary { background: var(--accent); color: #000; }
  .btn-primary:hover { background: #ffb820; transform: translateY(-1px); }
  .btn-secondary { background: transparent; border: 1px solid var(--border2); color: var(--text2); }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
  .btn-danger { background: transparent; border: 1px solid #e05050; color: #e05050; }
  .btn-danger:hover { background: #e05050; color: #fff; }
  .btn-success { background: var(--green); color: #000; }
  .btn-success:hover { background: #38d47e; }
  .btn-sm { padding: 5px 12px; font-size: 11px; }
  .btn-icon { padding: 6px 10px; }
  .btn-bar { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 14px; }

  /* ── TABLES ── */
  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  thead th {
    font-family: var(--cond);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text3);
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }
  tbody tr:hover { background: var(--bg3); }
  tbody td {
    padding: 9px 12px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text2);
  }
  tbody td.bus-num { color: var(--accent); font-weight: 600; }
  tbody td.route-cell { color: var(--blue); }
  tbody td.time-cell { color: var(--green); }

  .row-input {
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--mono);
    font-size: 12px;
    width: 100%;
    padding: 4px 6px;
    border-radius: 2px;
    outline: none;
    transition: background 0.1s;
  }
  .row-input:focus { background: var(--bg); }

  /* ── STATUS BADGES ── */
  .badge {
    display: inline-block;
    font-family: var(--cond);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
  }
  .badge-green  { background: rgba(45,190,108,.15); color: var(--green); border: 1px solid rgba(45,190,108,.3); }
  .badge-yellow { background: rgba(240,192,64,.15); color: var(--yellow); border: 1px solid rgba(240,192,64,.3); }
  .badge-red    { background: rgba(224,80,80,.15);  color: var(--red);    border: 1px solid rgba(224,80,80,.3); }
  .badge-blue   { background: rgba(74,158,255,.15); color: var(--blue);   border: 1px solid rgba(74,158,255,.3); }
  .badge-gray   { background: rgba(90,100,120,.15); color: var(--text3);  border: 1px solid var(--border); }

  /* ── ROUTE MAP EDITOR ── */
  .route-map-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .route-group-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 14px;
  }
  .route-group-title {
    font-family: var(--cond);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  /* ── OUTPUT SPECIFIC ── */
  .log-entry {
    font-family: var(--mono);
    font-size: 12px;
    padding: 7px 12px;
    border-left: 3px solid var(--border2);
    margin-bottom: 6px;
    background: var(--bg3);
    border-radius: 0 3px 3px 0;
    color: var(--text2);
  }
  .log-entry.perfect { border-left-color: var(--green); }
  .log-entry.similar { border-left-color: var(--yellow); }
  .log-entry.fallback { border-left-color: var(--red); }
  .log-entry.info    { border-left-color: var(--blue); }

  .nonop-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(224,80,80,.1);
    border: 1px solid rgba(224,80,80,.3);
    border-radius: 3px;
    padding: 5px 10px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--red);
    margin: 4px;
  }

  /* ── STATS BAR ── */
  .stats-bar {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .stat-box {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 20px;
    min-width: 120px;
    flex: 1;
  }
  .stat-value {
    font-family: var(--cond);
    font-size: 32px;
    font-weight: 900;
    line-height: 1;
    color: var(--accent);
  }
  .stat-label {
    font-family: var(--cond);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text3);
    margin-top: 4px;
  }

  /* ── EMPTY STATE ── */
  .empty-state {
    text-align: center;
    padding: 40px;
    color: var(--text3);
    font-family: var(--mono);
    font-size: 12px;
  }
  .empty-state-icon { font-size: 32px; margin-bottom: 10px; opacity: .4; }

  /* ── DIVIDER ── */
  .divider { height: 1px; background: var(--border); margin: 20px 0; }
  .section-label {
    font-family: var(--cond);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 12px;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

  /* ── TOAST ── */
  #toast {
    position: fixed;
    bottom: 24px; right: 24px;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-left: 3px solid var(--accent);
    color: var(--text);
    font-family: var(--mono);
    font-size: 12px;
    padding: 12px 18px;
    border-radius: 3px;
    z-index: 9999;
    transform: translateX(200%);
    transition: transform 0.25s ease;
    max-width: 320px;
  }
  #toast.show { transform: translateX(0); }

  .highlight-row td { background: rgba(240,165,0,.05) !important; }

  .output-row-perfect td:first-child { border-left: 3px solid var(--green); }
  .output-row-similar td:first-child { border-left: 3px solid var(--yellow); }
  .output-row-fallback td:first-child { border-left: 3px solid var(--red); }
  .output-row-unassigned td:first-child { border-left: 3px solid var(--text3); }

  /* ── MOBILE RESPONSIVE ── */
  @media (max-width: 768px) {
    /* Bus master span-2 col → full width on mobile */
    .bm-table-col { grid-column: span 1 !important; }

    /* Header */
    .header {
      padding: 0 14px;
      gap: 10px;
      height: auto;
      min-height: 50px;
      flex-wrap: wrap;
      padding-top: 8px;
      padding-bottom: 8px;
    }
    .header-title { font-size: 16px; letter-spacing: 1px; }
    .header-sub { font-size: 9px; letter-spacing: 1px; margin-left: 0; width: 100%; padding-bottom: 4px; }

    /* Tabs — scrollable row */
    .tabs {
      padding: 0 8px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      flex-wrap: nowrap;
      gap: 0;
    }
    .tab-btn {
      font-size: 11px;
      padding: 12px 12px;
      letter-spacing: 1px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* Main padding */
    .main { padding: 12px; }

    /* All multi-col grids → single column */
    .two-col,
    .three-col,
    .route-map-grid,
    div[style*="grid-template-columns:1fr 1fr 1fr"],
    div[style*="grid-template-columns: 1fr 1fr 1fr"],
    div[style*="grid-template-columns:1fr 1fr"],
    div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }

    /* Output layout — full width */
    div[style*="grid-column: span 2"],
    div[style*="grid-column:span 2"] {
      grid-column: span 1 !important;
    }

    /* Bus master 3-col grid */
    div[style*="grid-template-columns:1fr 1fr 1fr"] > div[style*="grid-column:span 2"] {
      grid-column: span 1 !important;
    }

    /* Card body */
    .card-body { padding: 12px; }
    .card-header { padding: 10px 12px; flex-wrap: wrap; gap: 6px; }

    /* Stats bar — 2 per row on mobile */
    .stats-bar { gap: 8px; }
    .stat-box {
      min-width: calc(50% - 4px);
      padding: 10px 12px;
      flex: 1 1 calc(50% - 4px);
    }
    .stat-value { font-size: 24px; }

    /* Buttons bar */
    .btn-bar { gap: 6px; }
    .btn {
      padding: 8px 14px;
      font-size: 12px;
      letter-spacing: 1px;
    }
    .btn-sm { padding: 5px 10px; font-size: 10px; }

    /* Textarea */
    textarea { font-size: 12px; }

    /* Table — horizontal scroll always */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    table { font-size: 12px; min-width: 480px; }
    thead th { font-size: 10px; padding: 8px 8px; }
    tbody td { padding: 7px 8px; font-size: 11px; }

    /* Logs */
    .log-entry { font-size: 11px; padding: 6px 10px; }

    /* JSONBin grid */
    div[style*="grid-template-columns:1fr 1fr;gap:16px"] {
      display: flex !important;
      flex-direction: column !important;
    }

    /* Toast */
    #toast {
      bottom: 12px;
      right: 12px;
      left: 12px;
      max-width: unset;
    }

    /* Chips / excluded */
    .nonop-chip { font-size: 11px; padding: 4px 8px; }
  }

  @media (max-width: 480px) {
    .header-title { font-size: 14px; }
    .tab-btn { font-size: 10px; padding: 10px 10px; }
    .stat-box { min-width: calc(50% - 4px); padding: 8px 10px; }
    .stat-value { font-size: 20px; }
    .main { padding: 8px; }
    .card-body { padding: 10px; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-icon">
    <svg viewBox="0 0 24 24"><path d="M3 17h18v2H3zm0-7h18v2H3zm0-7h18v2H3z"/></svg>
  </div>
  <div class="header-title">Fleet <span>Adjustment</span> System</div>
  <div class="header-sub">v2.0 · TIME-FIRST ALGORITHM</div>
</div>

<!-- TABS -->
<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('rowdata')">
    01 · Row Data
    <span class="tab-badge" id="badge-rowdata">0</span>
  </button>
  <button class="tab-btn" onclick="switchTab('partial')">
    02 · Partial Fleet
    <span class="tab-badge" id="badge-partial">0</span>
  </button>
  <button class="tab-btn" onclick="switchTab('busmaster')">
    03 · Bus Master
    <span class="tab-badge" id="badge-busmaster">0</span>
  </button>
  <button class="tab-btn" onclick="switchTab('output')">
    04 · Output
    <span class="tab-badge" id="badge-output">0</span>
  </button>
</div>

<!-- MAIN CONTENT -->
<div class="main">

  <!-- ══════════════════════════════════════════
       TAB 1: ROW DATA
  ═══════════════════════════════════════════ -->
  <div class="tab-panel active" id="tab-rowdata">
    <div class="two-col">
      <!-- RAW INPUT -->
      <div>
        <div class="card">
          <div class="card-header">
            <div class="card-title">📋 Raw Input Data</div>
          </div>
          <div class="card-body">
            <div class="section-label">Paste raw row data below</div>
            <textarea id="rawInput" rows="18" placeholder="Chembur - Bkc
C317
ALL
23/27
8:30 AM
C11
ALL
18/35
8:45 AM
Thane South Mumbai
C135
ALL
28/35
6:15 AM
C133
HN MN
35/35
6:55 AM"></textarea>
            <div class="btn-bar">
              <button class="btn btn-primary" onclick="cleanData()">⚡ Clean Data</button>
              <button class="btn btn-secondary" onclick="loadSampleData()">Load Sample</button>
              <button class="btn btn-danger btn-sm" onclick="clearRaw()">Clear</button>
            </div>
          </div>
        </div>
        <!-- Cleaning Rules Reference -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">📖 Parsing Rules</div>
          </div>
          <div class="card-body">
            <div style="font-family:var(--mono);font-size:11px;line-height:2;color:var(--text2);">
              <div style="color:var(--accent)">Multi-word city phrase  →  <span style="color:var(--text)">Main Route Header (sticky for all buses below)</span></div>
              <div style="color:var(--accent)">C317, C11, BV3  →  <span style="color:var(--text)">Bus / Vehicle Number</span></div>
              <div style="color:var(--accent)">ALL / HN MN / NTH EXP / KLS / VV  →  <span style="color:var(--text)">Route for that bus (never treated as header)</span></div>
              <div style="color:var(--accent)">23/27, 0/35, 35/35  →  <span style="color:var(--text)">Load — ALWAYS SKIPPED</span></div>
              <div style="color:var(--accent)">8:30 AM, 7:10 AM  →  <span style="color:var(--text)">Slot (Time) — closes the bus entry</span></div>
              <div style="margin-top:8px;color:var(--text3)">Auto-normalise: HN MN→HNMN · NTH EXP→NTH · KLS EXP→KLS</div>
              <div style="margin-top:4px;color:var(--text3)">Smart lookahead: if next line is a bus number, current line = header</div>
            </div>
          </div>
        </div>
      </div>

      <!-- CLEAN OUTPUT TABLE -->
      <div>
        <div class="card">
          <div class="card-header">
            <div class="card-title">✅ Cleaned Row Data</div>
            <div style="margin-left:auto;display:flex;gap:8px">
              <button class="btn btn-secondary btn-sm" onclick="exportClean()">Export CSV</button>
              <button class="btn btn-danger btn-sm" onclick="clearClean()">Clear</button>
            </div>
          </div>
          <div class="card-body" style="padding:0">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Main Route</th>
                    <th>Bus</th>
                    <th>Route</th>
                    <th>Slot (Time)</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="cleanTable">
                  <tr><td colspan="6"><div class="empty-state"><div class="empty-state-icon">🚌</div>Paste raw data and click "Clean Data"</div></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       TAB 2: PARTIAL FLEET
  ═══════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-partial">
    <div class="two-col">

      <!-- LEFT: RAW PASTE -->
      <div>
        <div class="card">
          <div class="card-header">
            <div class="card-title">📋 Raw Partial Fleet Data</div>
          </div>
          <div class="card-body">
            <div class="section-label">Same format as Row Data — paste directly</div>
            <textarea id="partialRawInput" rows="18" placeholder="Thane South Mumbai
C135
ALL
28/35
6:15 AM
C213
ALL
11/35
6:45 AM
C133
HN MN
35/35
6:55 AM
C227
NTH EXP
19/35
7:00 AM"></textarea>
            <div class="btn-bar">
              <button class="btn btn-primary" onclick="parsePartialData()">⚡ Parse Fleet</button>
              <button class="btn btn-secondary btn-sm" onclick="addPartialRow()">+ Add Row</button>
              <button class="btn btn-danger btn-sm" onclick="clearPartialRaw()">Clear</button>
            </div>
          </div>
        </div>
        <!-- Info card -->
        <div class="card">
          <div class="card-header"><div class="card-title">ℹ️ Format Guide</div></div>
          <div class="card-body">
            <div style="font-family:var(--mono);font-size:11px;line-height:2;color:var(--text2);">
              <div><span style="color:var(--accent)">Same rules as Row Data</span> — header, bus, route, load (skipped), time</div>
