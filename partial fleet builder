<script>
/* ═══════════════════════════════════════════════════
   DATA STORES
═══════════════════════════════════════════════════ */
let rowData    = [];   // [{mainRoute, bus, route, slot}]
let partialFleet = []; // [{slot, route, bus, mainRoute, notes}]
let busMaster  = [];   // [{bus, mainRoute, knownRoutes:[], driverBase}]
let outputResult = null;

/* ═══════════════════════════════════════════════════
   ROUTE GROUPS & MAPPINGS
═══════════════════════════════════════════════════ */
const ROUTE_GROUPS = {
  'THANE SOBO':   ['HNMN','ALL','NTH','VV','KLS','SOBO','THANE','LBS','MULUND'],
  'BKC CHEMBUR':  ['ALL','BKC','CHEMBUR','KURLA','CST','ANDHERI','COLABA','DADAR']
};

// All known main routes
const MAIN_ROUTE_KEYWORDS = {
  'THANE SOBO':  ['THANE','SOBO','THANESOBO','SOBOTHANE'],
  'BKC CHEMBUR': ['BKC','CHEMBUR','BKCCHEMBUR','CHEMBURB KC']
};

function detectMainRouteGroup(str) {
  const u = str.toUpperCase().replace(/\s+/g,'');
  for (const [grp, keys] of Object.entries(MAIN_ROUTE_KEYWORDS)) {
    for (const k of keys) {
      if (u.includes(k.replace(/\s+/g,''))) return grp;
    }
  }
  return str.toUpperCase().trim();
}

/* ═══════════════════════════════════════════════════
   ROUTE NORMALISATION
═══════════════════════════════════════════════════ */
function normaliseRoute(r) {
  if (!r) return 'ALL';
  r = r.trim().toUpperCase();

  // HN MN / HNMN variants → HNMN
  r = r.replace(/\bHN\s*MN\b/g, 'HNMN');

  // NTH EXP / NTH EXPRESS / NTH Exp → NTH
  r = r.replace(/\bNTH\s*(EXP(RESS)?)?\b/g, 'NTH').trim();
  if (r === 'NTH') r = 'NTH';   // keep clean

  // KLS EXP → KLS
  r = r.replace(/\bKLS\s*(EXP(RESS)?)?\b/g, 'KLS').trim();

  // VV EXP → VV
  r = r.replace(/\bVV\s*(EXP(RESS)?)?\b/g, 'VV').trim();

  // Collapse multiple spaces
  r = r.replace(/\s+/g, ' ').trim();

  return r || 'ALL';
}

function getMainRoute(route) {
  const r = normaliseRoute(route);
  for (const [grp, routes] of Object.entries(ROUTE_GROUPS)) {
    if (routes.includes(r)) return grp;
  }
  return null;
}

function isSimilarRoute(r1, r2) {
  const a = normaliseRoute(r1);
  const b = normaliseRoute(r2);
  if (a === b) return true;
  if (a === 'ALL' || b === 'ALL') return true;
  const g1 = getMainRoute(a);
  const g2 = getMainRoute(b);
  if (g1 && g2 && g1 === g2) return true;
  return false;
}

function isValidBus(busEntry, route) {
  if (!busEntry) return false;
  const r = normaliseRoute(route);
  const known = busEntry.knownRoutes.map(k => normaliseRoute(k));
  if (known.includes('ALL')) return true;
  if (known.includes(r)) return true;
  for (const k of known) {
    if (isSimilarRoute(k, r)) return true;
  }
  return false;
}

/* ═══════════════════════════════════════════════════
   PARSE / CLEAN RAW DATA
   ───────────────────────────────────────────────────
   HEADER vs ROUTE disambiguation rules:
   • A header MUST contain a city/place word OR a dash.
   • Route codes (HN MN, NTH EXP, KLS, VV, ALL…) contain
     NONE of these → never treated as headers, ever.
   • isBusNumber strictly requires  C<digits>  only.
   • isVehicleNumber handles BV3, ST12, etc.
   • isTimeString requires  H:MM  with optional AM/PM.
   • isLoadString matches  N/N  patterns → always skipped.
═══════════════════════════════════════════════════ */

/* ─── Known place/city words that appear ONLY in headers ─── */
const PLACE_WORDS = [
  'MUMBAI','THANE','CHEMBUR','MULUND','SOUTH','NORTH',
  'EAST','WEST','CENTRAL','SOBO','KURLA','DADAR',
  'BANDRA','WORLI','ANDHERI','BORIVALI','GHATKOPAR',
  'VIKHROLI','WADALA','SION','PAREL','MAHIM','COLABA',
  'CHURCHGATE','FORT','KALYAN','DOMBIVLI','BADLAPUR',
  'PANVEL','NAVI','VASHI','BELAPUR','AIROLI',
  'KHARGHAR','TALOJA','ULHASNAGAR','JOGESHWARI',
  'MALAD','KANDIVALI','GOREGAON','SANTACRUZ',
  'VILE','PARLE','CHARNI','GRANT','MARINE'
];

/* Note: BKC alone is NOT in PLACE_WORDS intentionally —
   "BKC" can appear as both a header component and a route.
   "Chembur - Bkc" has a dash → caught by dash rule.
   Pure "BKC" as a single-word line is treated as a route code.   */

/* ─── Primitive classifiers ─────────────────────────────── */
function isTimeString(s) {
  // Must be EXACTLY a time: 6:15 AM | 7:10 AM | 8:30 | 10:00 AM
  // Allows optional leading space, nothing else on the line
  return /^\d{1,2}:\d{2}(\s*(AM|PM))?$/i.test(s.trim());
}

function isLoadString(s) {
  // N/N pattern: 23/27 | 0/35 | 35/35
  return /^\d+\/\d+$/.test(s.trim());
}

function isBusNumber(s) {
  // STRICT: C then digits only, nothing else — C11, C317, C652
  return /^C\d+$/i.test(s.trim());
}

function isVehicleNumber(s) {
  // Non-C fleet with no spaces: BV3, ST12, AC01
  const t = s.trim();
  return /^[A-Z]{1,4}\d+$/i.test(t) && !isBusNumber(t);
}

function isKnownRouteCode(s) {
  // Explicitly known multi-word route codes that must NEVER be headers
  const u = s.trim().toUpperCase();
  const knownRoutes = [
    'HN MN','HNMN',
    'NTH EXP','NTH EXPRESS','NTH',
    'KLS EXP','KLS EXPRESS','KLS',
    'VV EXP','VV EXPRESS','VV',
    'LBS EXP','LBS',
    'ALL'
  ];
  return knownRoutes.includes(u);
}

/* ─── Main-route header detection (city/place keyword OR dash) ── */
function isMainRouteHeader(line) {
  const s = line.trim();
  if (!s)                   return false;
  if (isTimeString(s))      return false;
  if (isLoadString(s))      return false;
  if (isBusNumber(s))       return false;
  if (isVehicleNumber(s))   return false;
  if (isKnownRouteCode(s))  return false;  // ← explicit route-code guard

  const upper = s.toUpperCase();

  // Dash/hyphen → header  (e.g. "Chembur - Bkc", "Thane-SOBO")
  if (/[-–—]/.test(s)) return true;

  // Contains a city/place word → header
  if (PLACE_WORDS.some(p => new RegExp('\\b' + p + '\\b').test(upper))) return true;

  // Anything else (single or multi-word route codes not in known list) → NOT header
  return false;
}

/* ─── Main parser ────────────────────────────────────────── */
function parseData(rawText) {
  // Sanitise: strip smart-quotes, zero-width spaces, trailing quote-chars
  const raw = rawText
    .replace(/[\u201c\u201d\u2018\u2019\u201a\u201e\u2032\u2033"""'']/g, '')
    .replace(/[\u200b\u200c\u200d\ufeff]/g, '')
    .replace(/\u00a0/g, ' ')
    .trim();

  const lines = raw.split('\n')
                   .map(l => l.trim())
                   .filter(l => l.length > 0);

  const results = [];
  let currentMainRoute = 'UNKNOWN';
  let i = 0;

  while (i < lines.length) {
    const line = lines[i];

    /* ── CASE 1: Main-route header → update sticky context ── */
    if (isMainRouteHeader(line)) {
      currentMainRoute = line.toUpperCase().trim();
      i++;
      continue;
    }

    /* ── CASE 2: Bus / vehicle number → read its block ────── */
    if (isBusNumber(line) || isVehicleNumber(line)) {
      const bus = line.trim().toUpperCase();
      i++;

      let route = 'ALL';
      let slot  = '';

      // Read lines that belong to this bus until a boundary is hit
      while (i < lines.length) {
        const tok = lines[i].trim();

        // Boundary: next bus, next vehicle, or new header → stop
        if (isBusNumber(tok))      break;
        if (isVehicleNumber(tok))  break;
        if (isMainRouteHeader(tok)) break;

        // Load ratio → skip silently
        if (isLoadString(tok)) { i++; continue; }

        // Time → save as slot, then end this entry
        if (isTimeString(tok)) {
          slot = tok;
          i++;
          break;
        }

        // Anything remaining → route code for this bus
        // (covers ALL, HNMN, HN MN, NTH EXP, KLS, VV, etc.)
        route = tok;
        i++;
      }

      results.push({
        mainRoute: currentMainRoute,
        bus,
        route: normaliseRoute(route),
        slot:  normaliseTime(slot)
      });
      continue;
    }

    /* ── CASE 3: Unrecognised / orphan line → skip ─────────── */
    i++;
  }

  return results;
}

function normaliseTime(t) {
  if (!t) return '';
  t = t.trim();
  // Normalise to "H:MM AM/PM"
  const m = t.match(/(\d{1,2}):(\d{2})\s*(AM|PM)?/i);
  if (m) {
    const h = m[1], min = m[2], ampm = m[3] ? m[3].toUpperCase() : '';
    return `${h}:${min}${ampm ? ' '+ampm : ''}`;
  }
  return t;
}

/* ═══════════════════════════════════════════════════
   CLEAN DATA (UI)
═══════════════════════════════════════════════════ */
function cleanData() {
  const raw = document.getElementById('rawInput').value;
  if (!raw.trim()) { showToast('Paste raw data first'); return; }
  rowData = parseData(raw);
  renderCleanTable();
  updateBadge('rowdata', rowData.length);
  refreshMainRouteDropdown();
  showToast(`Parsed ${rowData.length} bus entries`);
}

function renderCleanTable() {
  const tbody = document.getElementById('cleanTable');
  if (!rowData.length) {
    tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><div class="empty-state-icon">🚌</div>No data</div></td></tr>';
    return;
  }
  tbody.innerHTML = rowData.map((r,i) => `
    <tr>
      <td style="color:var(--text3);font-size:11px">${i+1}</td>
      <td>${r.mainRoute}</td>
      <td class="bus-num">${r.bus}</td>
      <td class="route-cell">${r.route}</td>
      <td class="time-cell">${r.slot || '<span style="color:var(--text3)">—</span>'}</td>
      <td><button class="btn btn-danger btn-sm btn-icon" onclick="removeCleanRow(${i})">✕</button></td>
    </tr>
  `).join('');
}

function removeCleanRow(i) {
  rowData.splice(i,1);
  renderCleanTable();
  updateBadge('rowdata', rowData.length);
  refreshMainRouteDropdown();
}

// ── Auto-populate Main Route dropdown from Row Data ──
function refreshMainRouteDropdown() {
  const sel = document.getElementById('bm-mainroute');
  if (!sel) return;
  const currentVal = sel.value;
  // Collect unique mainRoutes from rowData
  const routes = [...new Set(rowData.map(r => r.mainRoute).filter(Boolean))].sort();
  sel.innerHTML = '<option value="">Select...</option>';
  routes.forEach(r => {
    const opt = document.createElement('option');
    opt.value = r;
    opt.textContent = r;
    if (r === currentVal) opt.selected = true;
    sel.appendChild(opt);
  });
  // Always keep current value if still valid
  if (currentVal && !routes.includes(currentVal)) {
    const opt = document.createElement('option');
    opt.value = currentVal;
    opt.textContent = currentVal;
    opt.selected = true;
    sel.appendChild(opt);
  }
}

function clearRaw() { document.getElementById('rawInput').value = ''; }
function clearClean() { rowData = []; renderCleanTable(); updateBadge('rowdata',0); }

function exportClean() {
  if (!rowData.length) { showToast('No data to export'); return; }
  const csv = ['Main Route,Bus,Route,Slot',
    ...rowData.map(r => `"${r.mainRoute}","${r.bus}","${r.route}","${r.slot}"`)
  ].join('\n');
  downloadFile(csv, 'row-data.csv', 'text/csv');
}

/* ═══════════════════════════════════════════════════
   PARTIAL FLEET
═══════════════════════════════════════════════════ */

function parsePartialData() {
  const raw = document.getElementById('partialRawInput').value;
  if (!raw.trim()) { showToast('Paste partial fleet data first'); return; }

  const parsed = parseData(raw);
  if (!parsed.length) { showToast('No valid entries found — check format'); return; }

  // Filter out excluded buses
  const skipped = [];
  const allowed = parsed.filter(p => {
    if (excludedBuses.has(p.bus)) { skipped.push(p.bus); return false; }
    return true;
  });

  const newEntries = allowed.map(p => ({
    slot:      p.slot,
    route:     p.route,
    bus:       p.bus,
    mainRoute: p.mainRoute,
    notes:     ''
  }));

  partialFleet.push(...newEntries);
  renderPartialTable();
  updateBadge('partial', partialFleet.length);

  let msg = `✓ ${newEntries.length} slots added`;
  if (skipped.length) msg += ` · ${skipped.length} excluded (${skipped.join(', ')})`;
  showToast(msg);
}

function addPartialRow(slot='', route='', bus='', mainRoute='', notes='') {
  partialFleet.push({ slot, route, bus, mainRoute, notes });
  renderPartialTable();
  updateBadge('partial', partialFleet.length);
}

// Build main route <select> dynamically from row data unique mainRoutes
function buildMainRouteSelect(idx, currentVal) {
  const routes = [...new Set(rowData.map(r => r.mainRoute).filter(Boolean))].sort();
  // Also include currentVal if not in rowData (e.g. manually set)
  if (currentVal && !routes.includes(currentVal)) routes.push(currentVal);

  let opts = `<option value="" ${!currentVal ? 'selected' : ''}>—</option>`;
  for (const mr of routes) {
    const sel = mr === currentVal ? 'selected' : '';
    opts += `<option value="${escHtml(mr)}" ${sel}>${escHtml(mr)}</option>`;
  }
  return `<select class="row-input" style="padding:4px 6px" onchange="partialFleet[${idx}].mainRoute=this.value">${opts}</select>`;
}

function renderPartialTable() {
  const tbody = document.getElementById('partialTable');
  if (!partialFleet.length) {
    tbody.innerHTML = '<tr><td colspan="7"><div class="empty-state"><div class="empty-state-icon">⏱</div>No partial fleet slots</div></td></tr>';
    return;
  }
  tbody.innerHTML = partialFleet.map((r, i) => `
    <tr>
      <td style="color:var(--text3);font-size:11px">${i + 1}</td>
      <td><input class="row-input" value="${escHtml(r.slot)}" placeholder="6:15 AM"
          onchange="partialFleet[${i}].slot=this.value" /></td>
      <td><input class="row-input" value="${escHtml(r.route)}" placeholder="HNMN"
          onchange="partialFleet[${i}].route=normaliseRoute(this.value)" /></td>
      <td><input class="row-input" value="${escHtml(r.bus)}" placeholder="C223"
          onchange="partialFleet[${i}].bus=this.value.toUpperCase()" /></td>
      <td>${buildMainRouteSelect(i, r.mainRoute)}</td>
      <td><input class="row-input" value="${escHtml(r.notes)}" placeholder="Notes..."
          onchange="partialFleet[${i}].notes=this.value" /></td>
      <td><button class="btn btn-danger btn-sm btn-icon" onclick="removePartialRow(${i})">✕</button></td>
    </tr>
  `).join('');
}

function removePartialRow(i) {
  partialFleet.splice(i, 1);
  renderPartialTable();
  updateBadge('partial', partialFleet.length);
}

function clearPartialRaw() {
  document.getElementById('partialRawInput').value = '';
}

function clearPartial() {
  partialFleet = [];
  renderPartialTable();
  updateBadge('partial', 0);
}

function exportPartial() {
  if (!partialFleet.length) { showToast('No data to export'); return; }
  const csv = ['Slot,Route,Bus,Main Route,Notes',
    ...partialFleet.map(r =>
      `"${r.slot}","${r.route}","${r.bus}","${r.mainRoute}","${r.notes}"`)
  ].join('\n');
  downloadFile(csv, 'partial-fleet.csv', 'text/csv');
}

// HTML escape helper to prevent XSS in inline values
function escHtml(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ═══════════════════════════════════════════════════
   BUS MASTER — CRUD
═══════════════════════════════════════════════════ */
function saveBusMaster() {
  const bus       = document.getElementById('bm-bus').value.trim().toUpperCase();
  const mainRoute = document.getElementById('bm-mainroute').value;
  const routes    = document.getElementById('bm-routes').value;
  const base      = document.getElementById('bm-base').value.trim();
  const editIdx   = parseInt(document.getElementById('bm-edit-index').value);

  if (!bus) { showToast('Bus number required'); return; }

  const entry = {
    bus,
    mainRoute,
    knownRoutes: routes.split(',').map(r => normaliseRoute(r.trim())).filter(Boolean),
    driverBase: base
  };

  if (editIdx >= 0) {
    busMaster[editIdx] = entry;
    document.getElementById('bm-edit-index').value = -1;
  } else {
    if (busMaster.find(b => b.bus === bus)) {
      showToast(`${bus} already exists — use Edit`); return;
    }
    busMaster.push(entry);
  }

  persistAll();
  renderBMTable();
  resetBMForm();
  updateBadge('busmaster', busMaster.length);
  showToast(`✓ Bus ${bus} saved`);
}

function editBus(i) {
  const b = busMaster[i];
  refreshMainRouteDropdown();
  document.getElementById('bm-bus').value       = b.bus;
  document.getElementById('bm-mainroute').value = b.mainRoute;
  document.getElementById('bm-routes').value    = b.knownRoutes.join(', ');
  document.getElementById('bm-base').value      = b.driverBase || '';
  document.getElementById('bm-edit-index').value = i;
  // Scroll form into view
  document.getElementById('bm-bus').scrollIntoView({ behavior:'smooth', block:'center' });
  document.getElementById('bm-bus').focus();
}

function deleteBus(i) {
  if (!confirm(`Delete bus ${busMaster[i].bus}?`)) return;
  busMaster.splice(i, 1);
  persistAll();
  renderBMTable();
  updateBadge('busmaster', busMaster.length);
  showToast('Bus deleted');
}

function cancelBMEdit() { resetBMForm(); }

function resetBMForm() {
  document.getElementById('bm-bus').value        = '';
  document.getElementById('bm-mainroute').value  = '';
  document.getElementById('bm-routes').value     = '';
  document.getElementById('bm-base').value       = '';
  document.getElementById('bm-edit-index').value = -1;
}

function renderBMTable() {
  const tbody = document.getElementById('bmTable');
  if (!busMaster.length) {
    tbody.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="empty-state-icon">📋</div>No buses registered yet</div></td></tr>';
    return;
  }
  tbody.innerHTML = busMaster.map((b, i) => {
    const isExcl = excludedBuses.has(b.bus);
    return `<tr ${isExcl ? 'style="opacity:.45"' : ''}>
      <td class="bus-num">${b.bus}${isExcl ? ' <span class="badge badge-red" style="font-size:9px">EXCL</span>' : ''}</td>
      <td style="color:var(--text2);font-size:12px">${b.mainRoute || '<span style="color:var(--text3)">—</span>'}</td>
      <td class="route-cell" style="font-size:11px">${b.knownRoutes.join(', ') || '<span style="color:var(--text3)">—</span>'}</td>
      <td style="color:var(--text2);font-size:12px">${b.driverBase || '<span style="color:var(--text3)">—</span>'}</td>
      <td style="white-space:nowrap">
        <button class="btn btn-secondary btn-sm" onclick="editBus(${i})">Edit</button>
        <button class="btn btn-danger btn-sm"    onclick="deleteBus(${i})">Del</button>
        ${isExcl
          ? `<button class="btn btn-secondary btn-sm" onclick="removeExcluded('${b.bus}')" title="Remove from exclusion">✓ Include</button>`
          : `<button class="btn btn-secondary btn-sm" style="border-color:#e05050;color:#e05050" onclick="excludeFromTable('${b.bus}')" title="Exclude from partial fleet">🚫 Exclude</button>`
        }
      </td>
    </tr>`;
  }).join('');
}

function clearBusMaster() {
  if (!confirm('Clear ALL bus master data? This cannot be undone.')) return;
  busMaster = [];
  persistAll();
  renderBMTable();
  updateBadge('busmaster', 0);
  showToast('Bus master cleared');
}

/* ═══════════════════════════════════════════════════
   EXCLUDED BUSES
   — buses that must NEVER appear in Partial Fleet
═══════════════════════════════════════════════════ */
let excludedBuses = new Set(); // Set of bus number strings

function addExcluded() {
  const raw = document.getElementById('excl-input').value.trim();
  if (!raw) return;
  // Support comma-separated input e.g. "C999, C888, C777"
  const nums = raw.split(/[,\s]+/).map(s => s.trim().toUpperCase()).filter(Boolean);
  nums.forEach(n => excludedBuses.add(n));
  document.getElementById('excl-input').value = '';
  persistAll();
  renderExcluded();
  renderBMTable(); // refresh EXCL badges
  showToast(`${nums.length} bus(es) excluded`);
}

function excludeFromTable(busNum) {
  excludedBuses.add(busNum.toUpperCase());
  persistAll();
  renderExcluded();
  renderBMTable();
  showToast(`${busNum} excluded from Partial Fleet`);
}

function removeExcluded(busNum) {
  excludedBuses.delete(busNum.toUpperCase());
  persistAll();
  renderExcluded();
  renderBMTable();
  showToast(`${busNum} included again`);
}

function clearExcluded() {
  if (!excludedBuses.size) return;
  if (!confirm('Clear all excluded buses?')) return;
  excludedBuses.clear();
  persistAll();
  renderExcluded();
  renderBMTable();
}

function renderExcluded() {
  const container = document.getElementById('excl-chips');
  const countEl   = document.getElementById('excl-count');
  countEl.textContent = `${excludedBuses.size} bus${excludedBuses.size !== 1 ? 'es' : ''}`;

  if (!excludedBuses.size) {
    container.innerHTML = '<span style="font-family:var(--mono);font-size:11px;color:var(--text3)">None added</span>';
    return;
  }
  container.innerHTML = [...excludedBuses].sort().map(b => `
    <div style="display:inline-flex;align-items:center;gap:5px;
         background:rgba(224,80,80,.12);border:1px solid rgba(224,80,80,.35);
         border-radius:3px;padding:4px 10px;font-family:var(--mono);
         font-size:12px;color:var(--red)">
      🚫 ${b}
      <button onclick="removeExcluded('${b}')"
        style="background:none;border:none;color:var(--text3);cursor:pointer;
               font-size:13px;line-height:1;padding:0 0 0 4px"
        title="Remove exclusion">×</button>
    </div>
  `).join('');
}

/* ═══════════════════════════════════════════════════
   PERSISTENCE — localStorage + JSONBin
═══════════════════════════════════════════════════ */

// ── Build the full data payload ──────────────────
function buildPayload() {
  return {
    busMaster,
    excludedBuses: [...excludedBuses],
    savedAt: new Date().toISOString()
  };
}

// ── localStorage (always used as fallback cache) ─
function saveToLocal() {
  try {
    localStorage.setItem('fas_busMaster', JSON.stringify(busMaster));
    localStorage.setItem('fas_excluded',  JSON.stringify([...excludedBuses]));
  } catch(e) { console.warn('localStorage write failed', e); }
}

function loadFromLocal() {
  try {
    const bm = localStorage.getItem('fas_busMaster');
    const ex = localStorage.getItem('fas_excluded');
    if (bm) busMaster = JSON.parse(bm);
    if (ex) excludedBuses = new Set(JSON.parse(ex));
  } catch(e) { console.warn('localStorage read failed', e); }
}

// ── persistAll: save local + auto-push ──────────
async function persistAll() {
  saveToLocal();
  const { apiKey, binId } = getJBConfig();
  if (apiKey && binId && apiKey !== 'YOUR_JSONBIN_API_KEY_HERE') {
    await pushToCloud(true); // silent push
  }
}

// ── JSONBin credentials — hardcoded in backend ──
const JB_API_KEY = 'YOUR_JSONBIN_API_KEY_HERE';
const JB_BIN_ID  = 'YOUR_JSONBIN_BIN_ID_HERE';

function saveJBConfig() { /* credentials are hardcoded, nothing to save */ }

// ── Helpers ──────────────────────────────────────
function getJBConfig() {
  // Always use hardcoded credentials — ignore hidden inputs
  return {
    apiKey: JB_API_KEY,
    binId:  JB_BIN_ID
  };
}

function setCloudStatus(state) {
  // state: 'ok' | 'error' | 'loading' | 'idle'
  const el = document.getElementById('cloud-status');
  const map = {
    ok:      ['badge-green', '● Connected'],
    error:   ['badge-red',   '✕ Error'],
    loading: ['badge-blue',  '⟳ Syncing…'],
    idle:    ['badge-gray',  'Not connected']
  };
  el.className = 'badge ' + (map[state][0] || 'badge-gray');
  el.textContent = map[state][1] || state;
}

// ── Test connection ───────────────────────────────
async function testJSONBin() {
  const { apiKey, binId } = getJBConfig();
  if (!apiKey || !binId || apiKey === 'YOUR_JSONBIN_API_KEY_HERE') {
    showToast('JSONBin credentials not configured'); return;
  }
  setCloudStatus('loading');
  try {
    const res = await fetch(`https://api.jsonbin.io/v3/b/${binId}/latest`, {
      headers: { 'X-Master-Key': apiKey }
    });
    if (res.ok) {
      setCloudStatus('ok');
      showToast('✓ JSONBin connected successfully');
    } else {
      const err = await res.json().catch(() => ({}));
      setCloudStatus('error');
      showToast(`JSONBin error: ${err.message || res.status}`);
    }
  } catch(e) {
    setCloudStatus('error');
    showToast('Network error — check API key / Bin ID');
  }
}

// ── Push data to cloud ────────────────────────────
async function pushToCloud(silent = false) {
  const { apiKey, binId } = getJBConfig();
  if (!apiKey || !binId) {
    if (!silent) showToast('Enter API Key and Bin ID first');
    return;
  }
  if (!silent) setCloudStatus('loading');
  try {
    const res = await fetch(`https://api.jsonbin.io/v3/b/${binId}`, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'X-Master-Key': apiKey
      },
      body: JSON.stringify(buildPayload())
    });
    if (res.ok) {
      setCloudStatus('ok');
      if (!silent) showToast('✓ Data pushed to cloud');
    } else {
      const err = await res.json().catch(() => ({}));
      setCloudStatus('error');
      if (!silent) showToast(`Push failed: ${err.message || res.status}`);
    }
  } catch(e) {
    setCloudStatus('error');
    if (!silent) showToast('Push failed — network error');
  }
}

// ── Pull data from cloud ──────────────────────────
async function pullFromCloud() {
  const { apiKey, binId } = getJBConfig();
  if (!apiKey || !binId) { showToast('Enter API Key and Bin ID first'); return; }
  setCloudStatus('loading');
  try {
    const res = await fetch(`https://api.jsonbin.io/v3/b/${binId}/latest`, {
      headers: { 'X-Master-Key': apiKey }
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      setCloudStatus('error');
      showToast(`Pull failed: ${err.message || res.status}`);
      return;
    }
    const json = await res.json();
    const data = json.record;

    if (data.busMaster)    busMaster     = data.busMaster;
    if (data.excludedBuses) excludedBuses = new Set(data.excludedBuses);

    // Refresh UI
    renderBMTable();
    renderExcluded();
    updateBadge('busmaster', busMaster.length);
    saveToLocal(); // cache locally too

    setCloudStatus('ok');
    showToast(`✓ Pulled ${busMaster.length} buses + ${excludedBuses.size} excluded`);
  } catch(e) {
    setCloudStatus('error');
    showToast('Pull failed — network error');
  }
}

/* ═══════════════════════════════════════════════════
   CORE ALGORITHM — adjustFleet()
═══════════════════════════════════════════════════ */
function adjustFleet() {
  if (!partialFleet.length) { showToast('No partial fleet data'); return; }
  if (!rowData.length)      { showToast('No row data cleaned'); return; }

  const logs = [];
  const results = [];
  const nonOps = [];
  const unassigned = [];
  const usedBuses = new Set(); // track buses already assigned in this run

  // Build lookup of row data buses (available pool)
  const rowBuses = new Set(rowData.map(r => r.bus));

  // Build row-data index keyed by bus for quick lookup
  const rowByBus = {};
  for (const r of rowData) rowByBus[r.bus] = r;

  // Step 3: For each partial fleet slot, find best replacement
  // (Non-Ops calculated AFTER assignment loop — see below)
  for (const slot of partialFleet) {
    const originalBus = slot.bus;
    const slotTime    = normaliseTime(slot.slot);
    const slotRoute   = normaliseRoute(slot.route || 'ALL');
    const slotMain    = slot.mainRoute;

    // Is the original bus available in row data? (must not be excluded)
    if (originalBus && rowByBus[originalBus] && !usedBuses.has(originalBus) && !excludedBuses.has(originalBus)) {
      // Original bus is fine — still in row data and not excluded
      usedBuses.add(originalBus);
      const rd = rowByBus[originalBus];
      results.push({
        slot: slotTime, route: slotRoute,
        originalBus, assignedBus: originalBus,
        matchType: 'original', reason: 'Bus present in row data',
        rowTime: rd.slot
      });
      logs.push({ type:'perfect', msg:`[${slotTime}] ${originalBus} retained (original bus in row data)` });
      continue;
    }

    // Original bus NOT available or excluded — need replacement
    if (originalBus && excludedBuses.has(originalBus)) {
      logs.push({ type:'info', msg:`[${slotTime}] ${originalBus} is EXCLUDED — finding replacement for route ${slotRoute}` });
    } else if (originalBus) {
      logs.push({ type:'info', msg:`[${slotTime}] ${originalBus} not in row data — finding replacement for route ${slotRoute}` });
    }

    // ── MAIN ROUTE NORMALISER ──
    // Raw mainRoute strings from parsed data can vary — normalise to canonical form.
    function normaliseMainRoute(mr) {
      if (!mr) return '';
      const u = mr.toUpperCase().replace(/\s+/g, ' ').trim();
      // Thane variants
      if (/THANE/.test(u) && (/SOUTH|SOBO|MUMBAI/.test(u))) return 'THANE SOBO';
      if (/^THANE\s*SOUTH\s*MUMBAI$/.test(u)) return 'THANE SOBO';
      // Mulund variants
      if (/MULUND/.test(u)) return 'MULUND SOBO';
      // Chembur - BKC variants (dash present or BKC keyword)
      if (/CHEMBUR/.test(u) && /BKC/.test(u)) return 'CHEMBUR BKC';
      if (/[-–—]/.test(u) && /BKC/.test(u))   return 'CHEMBUR BKC';
      if (/[-–—]/.test(u) && /CHEMBUR/.test(u)) return 'CHEMBUR BKC';
      // Chembur South Mumbai (no BKC)
      if (/CHEMBUR/.test(u) && /SOUTH|SOBO|MUMBAI/.test(u)) return 'CHEMBUR SOBO';
      // Fallback: return uppercased as-is
      return u;
    }

    // ── CANDIDATE POOL ──
    // HARD RULE: candidate's mainRoute MUST match slot's mainRoute exactly.
    // If slot has no mainRoute, skip the main-route boundary check.
    const normSlotMain = normaliseMainRoute(slotMain);

    const candidates = rowData.filter(r => {
      if (usedBuses.has(r.bus)) return false;
      if (excludedBuses.has(r.bus)) return false;   // HARD BLOCK: excluded buses never assigned
      if (!r.slot && slotTime) return false;

      // HARD BOUNDARY: main route must match
      if (normSlotMain) {
        const normCandMain = normaliseMainRoute(r.mainRoute);
        if (normCandMain !== normSlotMain) return false;
      }

      return true;
    });

    // ── EXACT ROUTE MATCH ONLY ──
    // Bus assigns only when route matches exactly.
    // ALL is universal — matches any route in both directions.
    // No similar/fallback assignments.

    function routeExactMatch(candidateRoute, targetRoute) {
      const cr = normaliseRoute(candidateRoute);
      const tr = normaliseRoute(targetRoute);
      if (cr === tr) return true;
      if (cr === 'ALL' || tr === 'ALL') return true;
      return false;
    }

    const exactCandidates = candidates.filter(c => routeExactMatch(c.route, slotRoute));

    // Among exact route matches, prefer same time first
    exactCandidates.sort((a, b) => {
      const aExact = slotTime && normaliseTime(a.slot) === slotTime ? 1 : 0;
      const bExact = slotTime && normaliseTime(b.slot) === slotTime ? 1 : 0;
      return bExact - aExact;
    });

    if (exactCandidates.length) {
      const best = exactCandidates[0];
      usedBuses.add(best.bus);

      const cTime  = normaliseTime(best.slot);
      const cRoute = normaliseRoute(best.route);

      let matchType, reason;
      if (cTime === slotTime) {
        matchType = 'perfect';
        reason = `Same time + exact route (${cRoute})`;
      } else {
        matchType = 'similar';
        reason = `Exact route (${cRoute}) — different time (${cTime})`;
      }

      results.push({
        slot: slotTime, route: slotRoute,
        originalBus, assignedBus: best.bus,
        matchType, reason,
        rowTime: cTime
      });

      const replaceTxt = originalBus ? `${best.bus} instead of ${originalBus}` : best.bus;
      logs.push({
        type: matchType === 'perfect' ? 'perfect' : 'similar',
        msg: `[${slotTime}] ${replaceTxt} — ${reason}`
      });

    } else {
      // No match — unassigned
      const noMatchReason = normSlotMain
        ? `No exact-route match in main route "${normSlotMain}" for ${slotRoute}`
        : `No exact-route match found for ${slotRoute}`;
      results.push({
        slot: slotTime, route: slotRoute,
        originalBus, assignedBus: null,
        matchType: 'unassigned', reason: noMatchReason,
        rowTime: ''
      });
      unassigned.push({ slot: slotTime, route: slotRoute, originalBus });
      logs.push({ type:'fallback', msg:`[${slotTime}] ⚠ ${noMatchReason} — slot unassigned` });
    }
  }

  // Calculate Non-Ops AFTER all assignments:
  // Non-Ops = buses in Row Data that were never assigned (not used) AND not excluded
  for (const rb of rowBuses) {
    if (!usedBuses.has(rb) && !excludedBuses.has(rb)) {
      nonOps.push(rb);
    }
  }
  if (nonOps.length) {
    logs.push({ type:'info', msg:`Non-Ops (unassigned from row data): ${nonOps.join(', ')}` });
  }

  outputResult = { results, logs, nonOps, unassigned };
  renderOutput();
  renderAdjustmentSummary();
  switchTab('output');
  updateBadge('output', results.length);
  showToast('Adjustment complete');
}

function renderAdjustmentSummary() {
  if (!outputResult) return;
  const { results, nonOps, unassigned } = outputResult;

  const total      = results.length;
  const assigned   = results.filter(r => r.assignedBus).length;
  const perfect    = results.filter(r => r.matchType === 'perfect' || r.matchType === 'original').length;
  const similar    = results.filter(r => r.matchType === 'similar').length;
  const unassignedN = results.filter(r => r.matchType === 'unassigned').length;
  const nonOpsN    = nonOps.length;

  const now = new Date();
  const timeStr = now.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });
  document.getElementById('summary-time').textContent = `Last run: ${timeStr}`;

  document.getElementById('summary-body').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
      <div style="background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:10px 12px">
        <div style="font-family:var(--cond);font-size:22px;font-weight:900;color:var(--accent);line-height:1">${total}</div>
        <div style="font-family:var(--cond);font-size:10px;letter-spacing:2px;color:var(--text3);margin-top:3px;text-transform:uppercase">Total Slots</div>
      </div>
      <div style="background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:10px 12px">
        <div style="font-family:var(--cond);font-size:22px;font-weight:900;color:var(--green);line-height:1">${assigned}</div>
        <div style="font-family:var(--cond);font-size:10px;letter-spacing:2px;color:var(--text3);margin-top:3px;text-transform:uppercase">Assigned</div>
      </div>
