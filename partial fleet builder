}

/* ═══════════════════════════════════════════════════
   RENDER OUTPUT
═══════════════════════════════════════════════════ */
function renderOutput() {
  if (!outputResult) return;
  const { results, logs, nonOps, unassigned } = outputResult;

  // Stats
  const perfect    = results.filter(r => r.matchType === 'perfect' || r.matchType === 'original').length;
  const similar    = results.filter(r => r.matchType === 'similar').length;
  const fallback   = results.filter(r => r.matchType === 'fallback').length;
  const unassignedN = results.filter(r => r.matchType === 'unassigned').length;

  document.getElementById('statsBar').style.display = 'flex';
  document.getElementById('stat-total').textContent = results.length;
  document.getElementById('stat-perfect').textContent = perfect;
  document.getElementById('stat-similar').textContent = similar;
  document.getElementById('stat-fallback').textContent = fallback;
  document.getElementById('stat-unassigned').textContent = unassignedN;
  document.getElementById('stat-nonops').textContent = nonOps.length;

  // Output table
  const tbody = document.getElementById('outputTable');
  if (!results.length) {
    tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state">No results</div></td></tr>';
  } else {
    tbody.innerHTML = results.map(r => {
      const cls = r.matchType === 'perfect' || r.matchType === 'original'
        ? 'output-row-perfect'
        : r.matchType === 'similar' ? 'output-row-similar'
        : r.matchType === 'fallback' ? 'output-row-fallback'
        : 'output-row-unassigned';

      const badge = r.matchType === 'perfect' || r.matchType === 'original'
        ? '<span class="badge badge-green">Perfect</span>'
        : r.matchType === 'similar'
        ? '<span class="badge badge-yellow">Similar</span>'
        : r.matchType === 'fallback'
        ? '<span class="badge badge-red">Fallback</span>'
        : '<span class="badge badge-gray">Unassigned</span>';

      const assignedCell = r.assignedBus
        ? `<span style="color:var(--accent);font-family:var(--mono)">${r.assignedBus}</span>`
        : '<span style="color:var(--text3)">—</span>';
      const origCell = r.originalBus
        ? `<span style="color:var(--text2);font-family:var(--mono);text-decoration:${r.assignedBus !== r.originalBus && r.originalBus ? 'line-through' : 'none'}">${r.originalBus}</span>`
        : '<span style="color:var(--text3)">—</span>';

      return `<tr class="${cls}">
        <td class="time-cell">${r.slot || '—'}</td>
        <td class="route-cell">${r.route}</td>
        <td>${origCell}</td>
        <td>${assignedCell}</td>
        <td>${badge}</td>
        <td style="color:var(--text3);font-size:11px">${r.reason}</td>
      </tr>`;
    }).join('');
  }

  // Non-Ops
  const nonOpsDiv = document.getElementById('nonOpsContainer');
  if (!nonOps.length) {
    nonOpsDiv.innerHTML = '<div class="empty-state" style="padding:20px"><div class="empty-state-icon">✓</div>None</div>';
  } else {
    nonOpsDiv.innerHTML = nonOps.map(b =>
      `<div class="nonop-chip">🚫 ${b}</div>`
    ).join('');
  }

  // Unassigned
  const unassignedDiv = document.getElementById('unassignedContainer');
  if (!unassigned.length) {
    unassignedDiv.innerHTML = '<div class="empty-state" style="padding:20px"><div class="empty-state-icon">✓</div>None</div>';
  } else {
    unassignedDiv.innerHTML = unassigned.map(u =>
      `<div class="log-entry fallback">⚠ ${u.slot || 'No time'} · ${u.route}${u.originalBus ? ' · orig: '+u.originalBus : ''}</div>`
    ).join('');
  }

  // Logs
  const logsDiv = document.getElementById('logsContainer');
  if (!logs.length) {
    logsDiv.innerHTML = '<div class="empty-state">No logs</div>';
  } else {
    logsDiv.innerHTML = logs.map(l =>
      `<div class="log-entry ${l.type}">${l.msg}</div>`
    ).join('');
  }
}

function clearOutput() {
  outputResult = null;
  document.getElementById('outputTable').innerHTML = '<tr><td colspan="6"><div class="empty-state"><div class="empty-state-icon">⚙️</div>Click "Run Adjustment"</div></td></tr>';
  document.getElementById('nonOpsContainer').innerHTML = '<div class="empty-state" style="padding:20px"><div class="empty-state-icon">✓</div>None</div>';
  document.getElementById('unassignedContainer').innerHTML = '<div class="empty-state" style="padding:20px"><div class="empty-state-icon">✓</div>None</div>';
  document.getElementById('logsContainer').innerHTML = '<div class="empty-state">No logs</div>';
  document.getElementById('statsBar').style.display = 'none';
  updateBadge('output', 0);
}

function exportOutput() {
  if (!outputResult) { showToast('Run adjustment first'); return; }
  const { results, nonOps } = outputResult;
  const csv = [
    'Slot,Route,Original Bus,Assigned Bus,Match Type,Reason',
    ...results.map(r =>
      `"${r.slot}","${r.route}","${r.originalBus||''}","${r.assignedBus||''}","${r.matchType}","${r.reason}"`)
  ].join('\n');
  downloadFile(csv, 'fleet-adjustment-output.csv', 'text/csv');
}

